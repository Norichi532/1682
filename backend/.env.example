# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database (pick one approach) ────────────────────────────
# Option A — connection string (takes priority)
DB_URL=postgresql://postgres:password@localhost:5432/phuong_tourist

# Option B — individual variables (used when DB_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=phuong_tourist
DB_USER=postgres
DB_PASSWORD=password

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=14d

# ── Bcrypt ───────────────────────────────────────────────────
BCRYPT_ROUNDS=10
